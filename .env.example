# AWS Bedrock API Key (generate from Bedrock console > API keys)
AWS_BEARER_TOKEN_BEDROCK=
AWS_DEFAULT_REGION=us-east-1

# Qlik Cloud (optional — pre-fills the plug icon form)
QLIK_TENANT_URL=
QLIK_OAUTH_CLIENT_ID=

# Comma-separated hostname suffixes to permit as tenants.
# Default allowlist is .qlikcloud.com and .qlik-stage.com — add custom domains
# (e.g. .your-company.com) only if you self-host a Qlik tenant.
QLIK_TENANT_ALLOWLIST=

# App
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
CHAINLIT_PORT=8000
